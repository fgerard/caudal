#!/usr/bin/env bash
# Caudal script

# Environment variables to determine startup behavior
#
# CAUDAL_BIN      Location of this file
# CAUDAL_HOME     Location of Caudal directory
# CAUDAL_LIB      Location of JAR dependency
# CAUDAL_CONFIG   Location of Config directory (*.clj and log4j2.xml)
# MINIMUM_MEMORY  Minimum Memory of JVM
# MAXIMUM_MEMORY  Maximum Memory of JVM
# TIMEZONE        ID for a TimeZone, either an abbreviation such as
#                 "PST", a full name such as "America/Los_Angeles", or
#                 a custom ID such as "GMT-8:00".

if test -z "$CAUDAL_BIN"; then
  export CAUDAL_BIN="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
fi

if test -z "$CAUDAL_HOME"; then
  export CAUDAL_HOME=$(dirname $CAUDAL_BIN)
fi

if test -z "$CAUDAL_DATA"; then
  export CAUDAL_DATA="$CAUDAL_HOME/data"
fi

if test -z "$CAUDAL_LIB"; then
  export CAUDAL_LIB="$CAUDAL_HOME/lib/*:$CAUDAL_HOME/target/*:$CAUDAL_HOME/ext/*"
fi

if test -z "$CAUDAL_CONFIG"; then
  export CAUDAL_CONFIG=$CAUDAL_HOME/config-yms/main.clj
fi

if test -z "$MININUM_MEMORY"; then
  export MININUM_MEMORY=1024m
fi

if test -z "$MAXIMUM_MEMORY"; then
  export MAXIMUM_MEMORY=1024m
fi

if test -z "$TIMEZONE"; then
  export TIMEZONE=America/Mexico_City
fi

# Caudal name & Java Class to start
export CAUDAL_NAME=caudal
export CAUDAL_STARTER=caudal.core.StarterDSL
export CAUDAL_PID=$CAUDAL_HOME/$CAUDAL_NAME.pid

start() {

  # Check for process already started in daemon mode
  if [ -f "$CAUDAL_PID" ] ; then
    pid=$( cat $CAUDAL_PID )
    verif=$( ps -fea | grep "$pid" | grep -v "grep" )
    if [ $? == 0 ] ; then
      echo "Caudal already started PID : $pid"
      exit 2
    else
      echo "Caudal PID file is orphan PID : $pid, deleting ..."
      rm $CAUDAL_PID
    fi
  fi

  # Check for JAVA
  echo "Verifying JAVA installation ..."
  if [[ -n "$JAVA_HOME" ]] && [[ -x "$JAVA_HOME/bin/java" ]];  then
    JAVA_BIN="$JAVA_HOME/bin/java"
  elif type -p java; then
    JAVA_BIN=java
  else
    echo "No JAVA installation found, please verify. Exiting ..."
    exit 1
  fi
  echo "Using JVM installed on : $JAVA_BIN ..."

  # Check version
  if [[ "$JAVA_BIN" ]]; then
    JAVA_VERSION=$("$JAVA_BIN" -version 2>&1 | awk -F '"' '/version/ {print $2}')
    MAYOR_DIGIT=$( echo $JAVA_VERSION | sed -n 's/\([0-9]*\)\..*/\1/p' )
    echo "JAVA Version : $JAVA_VERSION --> MAYOT_DIGIT: $MAYOR_DIGIT"
    if [ $MAYOR_DIGIT -ge "11" ]; then
      JVM_OPTS="-server"
    elif [ $MAYOR_DIGIT -gt "1" ]; then
      JVM_OPTS="-server -XX:+CMSParallelRemarkEnabled -XX:+AggressiveOpts -XX:+CMSClassUnloadingEnabled -XX:+IgnoreUnrecognizedVMOptions --add-modules=java.xml.bind"
    else
      JVM_OPTS="-server -XX:+UseConcMarkSweepGC -XX:+UseParNewGC -XX:+CMSParallelRemarkEnabled -XX:+AggressiveOpts -XX:+UseFastAccessorMethods -XX:+UseCompressedOops -XX:+CMSClassUnloadingEnabled"
    fi
  fi

  if test -d $CAUDAL_CONFIG
  then
    export CAUDAL_LIB=$CAUDAL_LIB:$CAUDAL_CONFIG
  elif test -f $CAUDAL_CONFIG
  then
    export CAUDAL_LIB=$CAUDAL_LIB:`dirname $CAUDAL_CONFIG`
  fi

  echo "CAUDAL_LIB: " $CAUDAL_LIB

  # java -cp "./lib/*:./config-linde/" caudal.core.StarterDSL -c config-linde/main.clj
  # Start: normal or daemon mode
  if [ -z "$CAUDAL_DAEMON" ] ; then
    echo $JAVA_BIN -Xms$MININUM_MEMORY -Xmx$MAXIMUM_MEMORY -Duser.timezone=$TIMEZONE $JVM_OPTS -cp "$CAUDAL_LIB" $CAUDAL_STARTER -c $CAUDAL_CONFIG
    $JAVA_BIN -Xms$MININUM_MEMORY -Xmx$MAXIMUM_MEMORY -Duser.timezone=$TIMEZONE $JVM_OPTS -cp "$CAUDAL_LIB" $CAUDAL_STARTER -c $CAUDAL_CONFIG
  else
    echo $JAVA_BIN -Xms$MININUM_MEMORY -Xmx$MAXIMUM_MEMORY -Duser.timezone=$TIMEZONE $JVM_OPTS -cp "$CAUDAL_LIB" $CAUDAL_STARTER -c $CAUDAL_CONFIG
    $JAVA_BIN -Xms$MININUM_MEMORY -Xmx$MAXIMUM_MEMORY -Duser.timezone=$TIMEZONE $JVM_OPTS -cp "$CAUDAL_LIB" $CAUDAL_STARTER -c $CAUDAL_CONFIG 2>&1 &

    retval=$?
    pid=$!

    echo "Using PID : $pid"

    echo "$pid" > $CAUDAL_PID
    [ $retval -eq 0 ] || exit $retval
    if ! ps -p $pid > /dev/null ; then
      exit 1
    fi
    exit 0
  fi
  exit $?
}

stop() {
  # Stop: daemon or normal mode
  if [ -f "$CAUDAL_PID" ] ; then
    pid=$( cat $CAUDAL_PID )
    kill $pid > /dev/null 2>&1
    rm $CAUDAL_PID
    while ps -fea | grep $pid | grep $CAUDAL_NAME > /dev/null ; do
      sleep 1
    done
    echo "Caudal stopped PID : $pid"
    exit 0
  else
    echo "Unable to find $CAUDAL_PID"
    exit 1
  fi
}

restart() {
  # Restarts only in daemon mode
  CAUDAL_DAEMON=true
  if [ -f "$CAUDAL_PID" ] ; then
    pid=$( cat $CAUDAL_PID )
    kill $pid > /dev/null 2>&1
    rm $CAUDAL_PID
    while ps -fea | grep $pid | grep $CAUDAL_NAME > /dev/null ; do
      sleep 1
    done
    echo
    start
  else
    echo "Unable to find $CAUDAL_PID"
    start
  fi
}

usage() {
    printf "Usage: caudal <option> <command>\n"
    printf "options:\n"
    printf "\t-d\tDaemonized option.\n"
    printf "\t-D\tUse development constants.\n"
    printf "\t-U\tSend events to https://ymsdashboard.gmodelo.com.mx/api"
    printf "\t-c\tTakes a custom configuration directory. Overrides CAUDAL_CONFIG environment variable.\n"
    printf "commands:\n"
    printf "\tstart\tStarts $CAUDAL_NAME servcie\n"
    printf "\tstop\tStops $CAUDAL_NAME service using $CAUDAL_PID\n"
    printf "\trestart\tStops and Start $CAUDAL_NAME service daemonized\n"
    printf "example:\n"
    printf "\tcaudal -c ./config/main.clj start\n\n"
    exit 1
}

while getopts "c:dhDU" opt; do
  case $opt in
    c)
      CAUDAL_CONFIG=$OPTARG
      ;;
    d)
      CAUDAL_DAEMON=true
      ;;
    D)
      export DEV=true
      ;;
    U)
      export DEV_URL="https://jarvis.gmodelo.com/api"
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      exit 1
      ;;
    :)
      echo "Option -$OPTARG requires an argument." >&2
      exit 1
      ;;
  esac
done

shift $(expr $OPTIND - 1 )
case $1 in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    restart
    ;;
  *)
    usage
    ;;
esac